datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          String    // ADMIN, MARKET_MANAGER, WORKER
  status        String    @default("INVITED") // INVITED, ACTIVE, SUSPENDED, DEACTIVATED
  hourlyWage    Float?
  manualWorkedHours Float?

  // Market membership (non-admin users belong to one market)
  // onDelete: SetNull — user stays in DB if market is deleted; requires manual reassignment
  market        Market?   @relation("UserMarket", fields: [marketId], references: [id], onDelete: SetNull)
  marketId      String?

  // Market Manager scope
  // onDelete: SetNull — manager stays if their market is deleted
  managedMarket   Market?   @relation("ManagedMarket", fields: [managedMarketId], references: [id], onDelete: SetNull)
  managedMarketId String?

  // onDelete: Restrict — do not silently delete work history; require explicit cleanup first
  jobs          JobAssignment[]
  createdJobs   Job[]     @relation("JobCreator")

  // onDelete: Restrict — preserve request audit trail
  releaseRequests ReleaseRequest[]
  shiftRequests   ShiftRequest[]

  // onDelete: Cascade — messages/notifications are owned by the user
  sentMessages     Message[]      @relation("SentMessages")
  notifications    Notification[]
  sentInvites      Invite[]       @relation("InviteSender")
  chatThreads      ChatThread[]

  // Audit trail of admin actions affecting payroll
  auditLogs     AuditLog[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Market {
  id        String   @id @default(cuid())
  name      String   @unique
  // onDelete: Restrict — can't delete store if it still has jobs; require cleanup first
  stores    Store[]
  users     User[]   @relation("UserMarket")
  managers  User[]   @relation("ManagedMarket")
  jobs      Job[]
  createdAt DateTime @default(now())
}

model Store {
  id        String   @id @default(cuid())
  name      String
  address   String
  latitude  Float
  longitude Float
  radius    Float    @default(100)

  // onDelete: Restrict — don't silently delete a store that belongs to a market with active jobs
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Restrict)
  marketId  String

  // onDelete: Restrict — jobs must be explicitly cleaned up before store deletion
  jobs      Job[]
  createdAt DateTime @default(now())
}

model Job {
  id           String   @id @default(cuid())
  title        String   @unique
  startTimeStr String   // HH:MM — e.g. "09:00"
  endTimeStr   String   // HH:MM — e.g. "17:00"
  date         DateTime?
  bonus        Float    @default(0)
  status       String   @default("OPEN") // OPEN, ASSIGNED, ACCEPTED, IN_PROGRESS, RECAP_PENDING, COMPLETED, NO_SHOW

  // Links a released-shift open job back to its source ReleaseRequest
  // Replaces fragile title-suffix matching used previously
  sourceReleaseId String?

  // onDelete: Restrict — job must not be deleted if it has active assignments (preserve work history)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  storeId   String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Restrict)
  marketId  String

  // onDelete: Restrict — preserve audit trail of who created the job
  createdBy User     @relation("JobCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  creatorId String

  // onDelete: Cascade — assignments, recaps, requests have no meaning without the parent job
  assignments     JobAssignment[]
  recaps          Recap[]
  releaseRequests ReleaseRequest[]
  shiftRequests   ShiftRequest[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model JobAssignment {
  id        String   @id @default(cuid())
  // onDelete: Cascade — assignment has no meaning if the job is deleted
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId     String
  // onDelete: Restrict — don't silently delete work history if worker is deleted
  worker    User     @relation(fields: [workerId], references: [id], onDelete: Restrict)
  workerId  String

  date        DateTime?
  dayOfWeek   Int?         // 0: Sunday, 1: Monday, etc.
  isRecurring Boolean      @default(false)

  clockIn   DateTime?
  clockOut  DateTime?
  breakTimeMinutes Int @default(0)
  workedHours      Float?
  status    String   @default("ASSIGNED") // ASSIGNED, IN_PROGRESS, RECAP_PENDING, COMPLETED, AVAILABLE

  // When status=AVAILABLE, this records who released it (original worker)
  releasedByWorkerId String?

  // Admin-overridable time bounds for this specific assignment
  // When set, these override job.startTimeStr / job.endTimeStr for this worker only
  customStartTimeStr String?
  customEndTimeStr   String?

  // Break records for this assignment (multiple breaks per shift supported)
  breaks    Break[]

  // onDelete: Cascade — recap is tied to assignment; if assignment deleted, recap is moot
  recap     Recap?

  createdAt DateTime @default(now())
}

// Records each break interval within a shift.
// breakTimeMinutes on JobAssignment is the denormalized sum of all completed Break.durationMins.
model Break {
  id           String        @id @default(cuid())
  assignment   JobAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String
  startTime    DateTime
  endTime      DateTime?     // null = break is currently active
  durationMins Float?        // computed when endTime is set
}

model ReleaseRequest {
  id        String   @id @default(cuid())
  // onDelete: Cascade — release request has no meaning without the job
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId     String
  // onDelete: Restrict — preserve audit trail
  worker    User     @relation(fields: [workerId], references: [id], onDelete: Restrict)
  workerId  String

  // Direct reference to the specific assignment being released
  assignmentId String?

  date        DateTime?
  dayOfWeek   Int?
  isRecurring Boolean      @default(false)

  status    String   @default("PENDING") // PENDING, APPROVED, DENIED
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShiftRequest {
  id        String   @id @default(cuid())
  // onDelete: Cascade — request has no meaning without the job
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId     String
  // onDelete: Restrict — preserve audit trail
  worker    User     @relation(fields: [workerId], references: [id], onDelete: Restrict)
  workerId  String

  // Direct reference to the AVAILABLE assignment being requested (new flow)
  assignmentId String?

  date        DateTime?
  dayOfWeek   Int?
  isRecurring Boolean      @default(false)

  status    String   @default("PENDING") // PENDING, APPROVED, DENIED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Recap {
  id                String   @id @default(cuid())
  // onDelete: Cascade — recap has no meaning without the job
  job               Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId             String
  // onDelete: Cascade — recap is entirely owned by the assignment
  assignment        JobAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId      String   @unique

  consumersAttended Int
  consumersSampled  Int
  reimbursement     Float    @default(0)
  receiptTotal      Float    @default(0)
  receiptUrl        String?
  comments          String?
  rushLevel         String?
  customerFeedback  String?
  managerSignature  String?  // Base64 drawn signature from store manager at the event
  storeManagerName  String?  // Typed name of the store manager who signed off at the event
  managerReview     String?  // Back-office admin notes written during recap approval
  status            String   @default("PENDING") // PENDING, APPROVED, REJECTED

  // onDelete: Cascade — overtime request tied to recap
  overtimeRequest   OvertimeRequest?

  // onDelete: Cascade — SKU rows tied to recap
  skus              RecapSKU[]

  createdAt         DateTime @default(now())
}

model OvertimeRequest {
  id        String   @id @default(cuid())
  // onDelete: Cascade — overtime request tied to recap
  recap     Recap    @relation(fields: [recapId], references: [id], onDelete: Cascade)
  recapId   String   @unique
  minutes   Int
  reason    String
  status    String   @default("PENDING") // PENDING, APPROVED, DENIED
  createdAt DateTime @default(now())
}

model RecapSKU {
  id                 String @id @default(cuid())
  // onDelete: Cascade — SKU rows have no meaning without the recap
  recap              Recap  @relation(fields: [recapId], references: [id], onDelete: Cascade)
  recapId            String
  skuName            String
  beginningInventory Int    @default(0)
  purchased          Int    @default(0)
  bottlesSold        Int    @default(0)
  storePrice         Float  @default(0)
}

model TrainingDocument {
  id          String   @id @default(cuid())
  title       String
  description String?
  url         String
  category    String   // PRODUCTS, POLICIES, PROCEDURES
  createdAt   DateTime @default(now())
}

model ChatThread {
  id           String    @id @default(cuid())
  type         String    @default("DIRECT") // MARKET_MANAGER, ADMIN, DIRECT
  participants User[]
  // onDelete: Cascade — messages owned by the thread
  messages     Message[]
  createdAt    DateTime  @default(now())
}

model Message {
  id        String     @id @default(cuid())
  // onDelete: Cascade — message has no meaning without the thread
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId  String
  // onDelete: Restrict — preserve message history even if sender is deleted
  sender    User       @relation("SentMessages", fields: [senderId], references: [id], onDelete: Restrict)
  senderId  String
  content   String
  createdAt DateTime   @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  // onDelete: Cascade — notifications are owned by the user
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Invite {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String   @unique
  role      String
  hourlyWage Float?
  marketId  String?
  storeId   String?
  // onDelete: Restrict — preserve audit of who sent the invite
  sender    User     @relation("InviteSender", fields: [senderId], references: [id], onDelete: Restrict)
  senderId  String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model InventoryItem {
  id        String   @id @default(cuid())
  name      String
  category  String?  // e.g. "white", "red"
  volume    String?  // e.g. "350"
  unit      String?  // e.g. "ml"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Immutable log of admin actions that affect payroll calculations.
// Written inside the same $transaction as the mutation — never outside.
model AuditLog {
  id         String   @id @default(cuid())
  actor      User     @relation(fields: [actorId], references: [id])
  actorId    String
  action     String   // SHIFT_TIME_EDIT, BREAK_MINUTES_OVERRIDE, RECAP_APPROVED, RECAP_REJECTED
  entityType String   // JobAssignment, Recap, Break
  entityId   String
  oldValue   String?  // JSON serialized (SQLite has no Json type)
  newValue   String?  // JSON serialized
  createdAt  DateTime @default(now())
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model UserReport {
  id          String   @id @default(cuid())
  reporterId  String
  reportedId  String
  reason      String
  status      String   @default("PENDING") // PENDING, RESOLVED
  createdAt   DateTime @default(now())
}
